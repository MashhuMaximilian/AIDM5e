# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DM_ROLE_NAME=Dungeon Master

# Optional local/dev tooling
GITHUB_TOKEN=

# Gemini
# Optional global fallback for local/dev use. In production BYOK mode,
# guild keys are stored in the database and this can stay blank.
GEMINI_API_KEY=
AIDM_KEY_ENCRYPTION_KEY=
GEMINI_CHAT_MODEL=gemini-3-flash-preview
GEMINI_TRANSCRIBE_MODEL=gemini-3.1-flash-lite-preview
GEMINI_SUMMARY_MODEL=gemini-3-flash-preview
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_HQ_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_DEFAULT_ASPECT_RATIO=4:3
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

# Supabase
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=aidm-session-archives

# Direct DB connection (either DIRECT_CONNECTION_STRING or the SUPABASE_DB_* fields)
DIRECT_CONNECTION_STRING=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require

# Audio / transcription
AUDIO_PROMPT=Transcribe this D&D session audio. The table may speak in Romanian, English, or mixed Romanian-English in the same sentence. Identify speakers if possible. Prefer best-effort speaker names and character names when clear, otherwise use Unknown. Distinguish in-character, out-of-character, and meta speech when possible.
AUDIO_CHUNK_SECONDS=1200
AUDIO_SUMMARY_WINDOW_CHUNKS=1
AUDIO_BITRATE=128k
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNELS=1
KEEP_AUDIO_FILES=false
KEEP_TRANSCRIPT_FILES=false
VOICE_INCLUDE_DM_CONTEXT=false

# Optional local context overrides / offline workflows
VOICE_PUBLIC_CONTEXT_PATH=
VOICE_SESSION_CONTEXT_PATH=
VOICE_DM_CONTEXT_PATH=

# FFMPEG input configuration
# macOS example: avfoundation / :0
# Linux example: pulse / default
# Windows example: dshow / <device name>
FFMPEG_INPUT_FORMAT=
FFMPEG_INPUT_DEVICE=

# App
LOG_LEVEL=INFO

# Future / currently unused
# ENABLE_FUNCTION_CALLING=true
# WRITE_TOOLS_SLASH_ONLY=true
# CONTEXT_AUTO_INCLUDE_DM_PLANNING=false
# DEFAULT_TELLDM_ALWAYS_ON=true
# ENVIRONMENT=production
